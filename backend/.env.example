# Puerto del servidor API
PORT=3001

# Conexión MySQL (en EasyPanel usa el host interno del servicio MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=lon
DB_PASSWORD=cambia-esto
DB_NAME=lon

# Token del panel de administrador. Genera uno fuerte:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=pon-aqui-un-token-largo-y-secreto

# Origen permitido para CORS (URL pública del frontend). Usa * solo en pruebas.
CORS_ORIGIN=*
